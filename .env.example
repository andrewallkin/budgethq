# Copy to `.env` and fill in real values. This file is safe to commit.

# -----------------------------------------------------------------------------
# Database (required)
# The backend builds DATABASE_URL from these vars only; DATABASE_URL is not read.
# With docker-compose.dev.yml, use host name `postgres`.
# -----------------------------------------------------------------------------
POSTGRES_USER=budget_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=budget_db
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# -----------------------------------------------------------------------------
# Compose published ports (optional; defaults 8000 / 3000)
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# Auth (required for register/login)
# Comma-separated list of allowed usernames (emails).
# -----------------------------------------------------------------------------
AUTHORIZED_USERS=you@example.com

# -----------------------------------------------------------------------------
# Encryption (required to store OpenAI or Investec API keys on a user)
# Fernet key, url-safe base64. Generate, for example:
#   uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Google Cloud / Sheets (optional — ETF price sync skips if unset)
# GCP_SERVICE_ACCOUNT_CREDENTIALS: base64-encoded JSON key (not a file path).
# -----------------------------------------------------------------------------
GCP_SERVICE_ACCOUNT_CREDENTIALS=
GOOGLE_SPREADSHEET_ID=

# -----------------------------------------------------------------------------
# Google Cloud Storage (optional — payslip PDF uploads)
# -----------------------------------------------------------------------------
GCS_PAYSLIPS_BUCKET_NAME=

# -----------------------------------------------------------------------------
# Logging (optional)
# LOG_FORMAT=json for JSON logs; REQUEST_LOGGING=true|1|yes enables request logging.
# -----------------------------------------------------------------------------
LOG_DIR=
LOG_FORMAT=
REQUEST_LOGGING=
